  "loops": [
    {
      "id": "blueprint-design",
      "start": "source-inventory",
      "nodes": [
        {
          "description": "Inventoi `.ballet/source-plane.yaml`:n eksplisiittisen `blueprint_scope`-valinnan kaikki ihmisen omistamat lähteet ja kirjoita deterministinen `.ballet/outputs/source-snapshot.yaml`, joka sitoutuu Git HEAD SHA:han, source-statuksiin, polkuihin ja raw-byte SHA-256 -hasheihin.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "source-inventory",
          "on": {
            "ready": {
              "action": "goto",
              "target": "source-validation"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Tarkista olemassa oleva snapshot täysin read-only-moodissa projektin source plane- ja governance-sääntöjä vasten. Todista ID:iden, statusten, viitteiden, scopejen, polkujen, Git SHA:n ja hashien eheys muuttamatta tai korjaamatta snapshotia ennen yhtäkään johdettua blueprint-artifactia.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "source-validation",
          "on": {
            "ready": {
              "action": "goto",
              "target": "gap-and-conflict-audit"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Kirjoita `.ballet/outputs/specification-gaps.yaml` ja luo `.ballet/outputs/decision-requests.yaml` vain, jos puuttuva, ristiriitainen, epäselvä tai hyväksymätön WHAT/WHY-päätös blokkaa työn. Älä muuta puutetta oletukseksi.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "gap-and-conflict-audit",
          "on": {
            "ready": {
              "action": "goto",
              "target": "roadmap"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Ratkaise decision request päivittämällä ja hyväksymällä ihmisen omistama lähde. Gate-vastaus ei itsessään ole uusi source authority. Approved käynnistää uuden inventoinnin ja snapshotin; rejected päättää Runin blokattuna.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "source-decision-gate",
          "on": {
            "approved": {
              "action": "goto",
              "target": "source-inventory",
              "input": "append-signal"
            },
            "rejected": {
              "action": "goto",
              "target": "blocked",
              "input": "append-signal"
            }
          },
          "type": "human"
        },
        {
          "description": "Johda validoiduista hyväksytyistä lähteistä vertikaaliset toimitusslicet `.ballet/outputs/roadmap.yaml`:iin. Säilytä source- ja acceptance-viitteet, riippuvuudet, riskit ja validointipisteet.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "roadmap",
          "on": {
            "ready": {
              "action": "goto",
              "target": "domain-map"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Johda source-backed domainit, vastuut, omistajuudet ja suhteet `.ballet/outputs/domain-map.yaml`:iin ilman uutta tuote-, alusta- tai data-päätöstä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "domain-map",
          "on": {
            "ready": {
              "action": "goto",
              "target": "c4-context-container"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Johda domain- ja system context sekä C4 context/container `.ballet/outputs/c4-context-container.yaml`:iin. Jätä teknologia nulliksi, ellei saman scopen hyväksytty lähde päätä sitä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "c4-context-container",
          "on": {
            "ready": {
              "action": "goto",
