        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "technical-plan-gate",
      "description": "Gate 4: Human approval of the reviewed Technical Plan before milestone planning continues.",
