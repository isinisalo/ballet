{
  "version": 8,
  "agents": {
    "acceptance-test-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "architecture-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "implementation-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "implementation-plan-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "milestone-issues-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "release-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "roadmap-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "test-plan-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "ui-design-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    }
  },
  "loops": [
    {
      "id": "blueprint-design",
      "start": "roadmap",
      "nodes": [
        {
          "description": "Muodosta hyväksytyistä Goal- ja ADR-lähteistä roadmap tiedostoon .ballet/outputs/ROADMAP.md. Rajaa MVP, myöhemmät inkrementit, riippuvuudet, riskit ja validointipisteet.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "roadmap",
          "on": {
            "ready": "data-model",
            "approved": "data-model",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "blueprint-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Johda hyväksytystä roadmapista projektin domain-, data- ja integraatiomalli tiedostoon .ballet/outputs/DATA-MODEL.md ilman uutta WHAT- tai WHY-päätöstä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "data-model",
          "on": {
            "ready": "ui-design",
            "approved": "ui-design",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "blueprint-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Suunnittele roadmapin ja data-mallin mukainen käyttöliittymärakenne tiedostoon .ballet/outputs/UI-DESIGN.md käyttäen projektin DESIGN.md-tokeneita.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "ui-design",
          "on": {
            "ready": "ui-mocks",
            "approved": "ui-mocks",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "blueprint-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "ui-design-agent"
        },
        {
          "description": "Tuota UI-DESIGN.md:n perusteella tarkistettavat näkymä- ja tilamockit tiedostoon .ballet/outputs/UI-MOCKS.md.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "ui-mocks",
          "on": {
            "ready": "c4-models",
            "approved": "c4-models",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "blueprint-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "ui-design-agent"
        },
        {
          "description": "Kuvaa hyväksytyn data-mallin ja UI-ratkaisun C4 context-, container- ja component-tasolla tiedostoon .ballet/outputs/C4.md.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "c4-models",
          "on": {
            "ready": "blueprint-gate",
            "approved": "blueprint-gate",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "blueprint-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Hyväksy ROADMAP-, DATA-MODEL-, UI-DESIGN-, UI-MOCKS- ja C4-artifactit. Approved-vastauksen tulee sisältää milestone_id sekä vähintään yksi github_issue-handoff seuraavaa Looppia varten.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "blueprint-gate",
          "on": {
            "approved": {
              "loop": "milestone-planning"
            },
            "rejected": "roadmap"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    },
    {
      "id": "milestone-planning",
      "start": "plan-milestone-issues",
      "nodes": [
        {
          "description": "Lue blueprint-artifactit ja human handoff, hae GitHub-issueiden nykyinen sisältö ja tuota milestone-kohtainen rajaus, riippuvuudet, acceptance criteria ja issue-snapshotit .ballet/outputs/milestones/<milestone-id>/MILESTONE.md-tiedostoon.",
          "nodeStyle": "luna",
          "nodeSize": "medium",
          "id": "plan-milestone-issues",
          "on": {
            "ready": "implementation-plan",
            "approved": "implementation-plan",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "milestone-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "milestone-issues-agent"
        },
        {
          "description": "Laadi valitulle milestonelle päätöksistä johdettu toteutussuunnitelma tiedostoon .ballet/outputs/milestones/<milestone-id>/IMPLEMENTATION-PLAN.md.",
          "nodeStyle": "luna",
          "nodeSize": "medium",
          "id": "implementation-plan",
          "on": {
            "ready": "test-plan",
            "approved": "test-plan",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "milestone-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "implementation-plan-agent"
        },
        {
          "description": "Määrittele milestonen unit-, integration-, acceptance- ja release-verifioinnit tiedostoon .ballet/outputs/milestones/<milestone-id>/TEST-PLAN.md.",
          "nodeStyle": "luna",
          "nodeSize": "medium",
          "id": "test-plan",
          "on": {
            "ready": "milestone-gate",
            "approved": "milestone-gate",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "milestone-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "test-plan-agent"
        },
        {
          "description": "Hyväksy valitun milestonen rajaus, GitHub-issue snapshotit, toteutussuunnitelma ja testisuunnitelma toteutuksen lähtökohdaksi.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "milestone-gate",
          "on": {
            "approved": {
              "loop": "milestone-delivery"
            },
            "rejected": "plan-milestone-issues"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    },
    {
      "id": "milestone-delivery",
      "start": "implement-milestone",
      "nodes": [
        {
          "description": "Toteuta hyväksytyn milestonen kaikki määritellyt GitHub-issues-muutokset ja testit IMPLEMENTATION-PLAN.md:n, TEST-PLAN.md:n ja UI-artifacttien mukaisesti.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "implement-milestone",
          "on": {
            "ready": "run-acceptance-tests",
            "approved": "run-acceptance-tests",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "implementation-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "implementation-agent"
        },
        {
          "description": "Aja milestonen TEST-PLAN.md:n acceptance-testit, tarkasta diff ja tallenna evidenssi tiedostoon .ballet/outputs/milestones/<milestone-id>/ACCEPTANCE.md muuttamatta toteutusta.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "run-acceptance-tests",
          "on": {
            "ready": "implementation-gate",
            "approved": "implementation-gate",
            "changes-requested": { "repair": "implement-milestone" },
            "needs_input": { "human": "implementation-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "acceptance-test-agent"
        },
        {
          "description": "Hyväksy milestonen toteutus ja acceptance-evidenssi julkaistavaksi CI/CD-ketjun kautta.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "implementation-gate",
          "on": {
            "approved": {
              "loop": "release-validation"
            },
            "rejected": "implement-milestone"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    },
    {
      "id": "release-validation",
      "start": "make-git-release",
      "nodes": [
        {
          "description": "Tarkista implementation-gate, muodosta projektin määrittelemä Git-release ja tallenna release-versio sekä komennot release-artifactiin.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "make-git-release",
          "on": {
            "ready": "deploy-release",
            "approved": "deploy-release",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "release-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "release-agent"
        },
        {
          "description": "Käynnistä vain projektin olemassa oleva CI/CD-deploy valitulle Git-releaselle ja tallenna workflow-runin evidenssi release-artifactiin.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "deploy-release",
          "on": {
            "ready": "verify-release",
            "approved": "verify-release",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "release-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "release-agent"
        },
        {
          "description": "Verifioi deploy health-, smoke-, acceptance- ja observability-checkeillä sekä kirjaa tulokset ja mahdollisen rollbackin release-artifactiin.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "verify-release",
          "on": {
            "ready": "release-gate",
            "approved": "release-gate",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "release-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "release-agent"
        },
        {
          "description": "Tarkasta release-, deploy- ja verifiointievidenssi. Rejection palauttaa verifiointiin eikä luo uutta Git-tagia.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "release-gate",
          "on": {
            "approved": "completed",
            "rejected": "verify-release"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    }
  ]
}
