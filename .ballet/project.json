            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Muunna vain hyväksytyt quality policy -vaatimukset mitattaviksi `.ballet/outputs/quality-scenarios.yaml`-skenaarioiksi. Puuttuva raja-arvo on päätöspyyntö, ei oletus.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "quality-scenarios",
          "on": {
            "ready": {
              "action": "goto",
              "target": "threat-model"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Johda assetit, trust boundaryt, uhkat, lähdepohjaiset mitigoinnit ja residual riskit `.ballet/outputs/threat-model.yaml`:iin ilman live-probausta, credentialeja tai riskin hyväksymistä ihmisen puolesta.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "threat-model",
          "on": {
            "ready": {
              "action": "goto",
