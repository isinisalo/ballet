  "workflows": [
    {
      "id": "adr_goals_changed.loop",
      "title": "brief-loop",
      "steps": [
        "on.trigger.adr_goals_changed.start.create-project-brief",
        "on.create-project-brief.ready.start.challenge-project-brief",
        "on.challenge-project-brief.approved.start.project-brief-gate",
        "on.project-brief-gate.changes_requested.start.create-project-brief",
        "on.challenge-project-brief.changes_requested.start.create-project-brief",
        "on.create-project-brief.blocked.start.done"
      ]
    },
    {
      "id": "project-brief-gate.approved.loop",
      "title": "2. Roadmap loop",
      "steps": [
        "on.trigger.project-brief-gate.approved.start.create-roadmap",
        "on.create-roadmap.ready.start.challenge-roadmap",
        "on.challenge-roadmap.approved.start.roadmap-gate",
        "on.roadmap-gate.changes_requested.start.create-roadmap",
        "on.challenge-roadmap.changes_requested.start.create-roadmap",
        "on.create-roadmap.blocked.start.done"
      ]
    },
    {
