{
  "version": 1,
  "triggers": [
    {
      "id": "intent_changed",
      "description": "Human-approved Goal or ADR changed and roadmap analysis can start."
    },
    {
      "id": "roadmap_approved",
      "description": "Human approved the agent-produced roadmap."
    },
    {
      "id": "implementation_plan_approved",
      "description": "Human approved the implementation plan, acceptance criteria, and Definition of Done."
    },
    {
      "id": "review_gate_approved",
      "description": "Human approved the review gate and release preparation can start."
    },
    {
      "id": "release_approved",
      "description": "Human approved deployment to a non-production environment."
    },
    {
      "id": "production_deploy_approved",
      "description": "Human approved production deployment."
    },
    {
      "id": "ci_or_validation_failed",
      "description": "CI, lint, build, test, or runtime validation failed."
    },
    {
      "id": "incident_reported",
      "description": "A user, runtime, or monitor reported an operational issue."
    }
  ],
  "actions": [
    {
      "id": "route-project",
      "description": "Select the next workflow path without doing role work.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "project-orchestrator"
      ]
    },
    {
      "id": "route-delivery",
      "description": "Select the next workflow path without doing role work.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "delivery-orchestrator"
      ]
    },
    {
      "id": "analyze-intent",
      "description": "Read Goals and ADRs, identify scope, limits, and unresolved decisions.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "intent-reviewer"
      ]
    },
    {
      "id": "design-roadmap",
      "description": "Break approved intent into traceable roadmap or backlog items.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "roadmap-designer"
      ]
    },
    {
      "id": "design-release",
      "description": "Create an implementation-ready plan, acceptance criteria, tests, and Definition of Done.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "release-designer"
      ]
    },
    {
      "id": "design-ui",
      "description": "Create or review UI/UX design evidence for the approved scope.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "ux-designer"
      ]
    },
    {
      "id": "implement",
      "description": "Implement the approved plan as the smallest safe code change.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "developer-agent"
      ]
    },
    {
      "id": "verify",
      "description": "Run or assess acceptance, regression, lint, build, and test evidence.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "qa-agent"
      ]
    },
    {
      "id": "review-feasibility",
      "description": "Review implementation evidence from one role-specific perspective.",
      "outputIds": [
        "approved",
        "changes_requested",
        "done"
      ],
      "agentIds": [
        "feasibility-reviewer"
      ]
    },
    {
      "id": "review-intent",
      "description": "Review implementation evidence from one role-specific perspective.",
      "outputIds": [
        "changes_requested",
        "done"
      ],
      "agentIds": [
        "intent-reviewer"
      ]
    },
    {
      "id": "review-architect",
      "description": "Review implementation evidence from one role-specific perspective.",
      "outputIds": [
        "approved",
        "changes_requested",
        "done"
      ],
      "agentIds": [
        "architecture-reviewer"
      ]
    },
    {
      "id": "review-qa-verification-reviewer",
      "description": "Review implementation evidence from one role-specific perspective.",
      "outputIds": [
        "approved",
        "changes_requested",
        "done"
      ],
      "agentIds": [
        "qa-verification-reviewer"
      ]
    },
    {
      "id": "review-ops",
      "description": "Review implementation evidence from one role-specific perspective.",
      "outputIds": [
        "approved",
        "changes_requested",
        "done"
      ],
      "agentIds": [
        "ops-release-reviewer"
      ]
    },
    {
      "id": "aggregate-review",
      "description": "Combine role-specific reviews into one review gate decision.",
      "outputIds": [
        "approved",
        "changes_requested",
        "blocked"
      ],
      "agentIds": [
        "review-orchestrator"
      ]
    },
    {
      "id": "document",
      "description": "Update documentation needed before release preparation.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "documentation-agent"
      ]
    },
    {
      "id": "document-release",
      "description": "Record release or deployment evidence after a deploy completes.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "documentation-agent"
      ]
    },
    {
      "id": "prepare-deploy",
      "description": "Check release, rollback, configuration, migration, and observability readiness.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "devops-agent"
      ]
    },
    {
      "id": "review-release",
      "description": "Review release preparation without colliding with implementation review events.",
      "outputIds": [
        "approved",
        "changes_requested",
        "blocked"
      ],
      "agentIds": [
        "ops-release-reviewer"
      ]
    },
    {
      "id": "deploy",
      "description": "Execute an explicitly approved deployment.",
      "outputIds": [
        "deployed",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "devops-agent"
      ]
    },
    {
      "id": "troubleshoot",
      "description": "Diagnose a failed check, runtime failure, or deploy failure and produce a correction plan.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "troubleshooter"
      ]
    },
    {
      "id": "triage-incident",
      "description": "Diagnose an incident and route it toward a planned correction instead of direct implementation.",
      "outputIds": [
        "ready",
        "blocked",
        "failed"
      ],
      "agentIds": [
        "troubleshooter"
      ]
    },
    {
      "id": "done",
      "description": "No further actions.",
      "outputIds": [],
      "agentIds": []
    }
  ],
  "outputs": [
    {
      "id": "ready",
      "description": "Action produced usable evidence for the next agent or human gate.",
      "type": "event"
    },
    {
      "id": "approved",
      "description": "Review gate approved this perspective.",
      "type": "event"
    },
    {
      "id": "changes_requested",
      "description": "Review gate requires corrections before continuing.",
      "type": "event"
    },
    {
      "id": "blocked",
      "description": "Action cannot continue without a human decision, missing dependency, or conflict resolution.",
      "type": "event"
    },
    {
      "id": "failed",
      "description": "Action failed technically or at runtime.",
      "type": "event"
    },
    {
      "id": "deployed",
      "description": "Deployment completed in the approved environment.",
      "type": "event"
    },
    {
      "id": "done",
      "description": "Workflow is done.",
      "type": "gate"
    }
  ],
  "policies": [
    {
      "source": "trigger",
      "trigger": "intent_changed",
      "action": "route-project",
      "enabled": true,
      "id": "on.trigger.intent_changed.start.route-project"
    },
    {
      "source": "event",
      "event": "route-project.ready",
      "action": "analyze-intent",
      "enabled": true,
      "id": "on.route-project.ready.start.analyze-intent"
    },
    {
      "source": "event",
      "event": "analyze-intent.ready",
      "action": "design-roadmap",
      "enabled": true,
      "id": "on.analyze-intent.ready.start.design-roadmap"
    },
    {
      "source": "trigger",
      "trigger": "roadmap_approved",
      "action": "design-release",
      "enabled": true,
      "id": "on.trigger.roadmap_approved.start.design-release"
    },
    {
      "source": "trigger",
      "trigger": "roadmap_approved",
      "action": "design-ui",
      "enabled": true,
      "id": "on.trigger.roadmap_approved.start.design-ui"
    },
    {
      "source": "event",
      "event": "design-release.ready",
      "action": "review-feasibility",
      "enabled": true,
      "id": "on.design-release.ready.start.review-feasibility"
    },
    {
      "source": "event",
      "event": "design-ui.ready",
      "action": "review-feasibility",
      "enabled": true,
      "id": "on.design-ui.ready.start.review-feasibility"
    },
    {
      "source": "event",
      "event": "review-feasibility.changes_requested",
      "action": "design-release",
      "enabled": true,
      "id": "on.review-feasibility.changes_requested.start.design-release"
    },
    {
      "source": "event",
      "event": "review-feasibility.changes_requested",
      "action": "design-ui",
      "enabled": true,
      "id": "on.review-feasibility.changes_requested.start.design-ui"
    },
    {
      "source": "trigger",
      "trigger": "implementation_plan_approved",
      "action": "route-delivery",
      "enabled": true,
      "id": "on.trigger.implementation_plan_approved.start.route-delivery"
    },
    {
      "source": "event",
      "event": "route-delivery.ready",
      "action": "implement",
      "enabled": true,
      "id": "on.route-delivery.ready.start.implement"
    },
    {
      "source": "event",
      "event": "implement.ready",
      "action": "verify",
      "enabled": true,
      "id": "on.implement.ready.start.verify"
    },
    {
      "source": "event",
      "event": "verify.ready",
      "action": "review-intent",
      "enabled": true,
      "id": "on.verify.ready.start.review-intent"
    },
    {
      "source": "event",
      "event": "verify.ready",
      "action": "review-architect",
      "enabled": true,
      "id": "on.verify.ready.start.review-architect"
    },
    {
      "source": "event",
      "event": "verify.ready",
      "action": "review-qa-verification-reviewer",
      "enabled": true,
      "id": "on.verify.ready.start.review-qa-verification-reviewer"
    },
    {
      "source": "event",
      "event": "verify.ready",
      "action": "review-ops",
      "enabled": true,
      "id": "on.verify.ready.start.review-ops"
    },
    {
      "source": "event",
      "event": "review-qa-verification-reviewer.approved",
      "action": "aggregate-review",
      "enabled": true,
      "id": "on.review-qa-verification-reviewer.approved.start.aggregate-review"
    },
    {
      "source": "event",
      "event": "review-intent.changes_requested",
      "action": "analyze-intent",
      "enabled": true,
      "id": "on.review-intent.changes_requested.start.analyze-intent"
    },
    {
      "source": "event",
      "event": "review-architect.changes_requested",
      "action": "route-delivery",
      "enabled": true,
      "id": "on.review-architect.changes_requested.start.route-delivery"
    },
    {
      "source": "event",
      "event": "review-qa-verification-reviewer.changes_requested",
      "action": "route-delivery",
      "enabled": true,
      "id": "on.review-qa-verification-reviewer.changes_requested.start.route-delivery"
    },
    {
      "source": "event",
      "event": "review-ops.changes_requested",
      "action": "route-delivery",
      "enabled": true,
      "id": "on.review-ops.changes_requested.start.route-delivery"
    },
    {
      "source": "event",
      "event": "aggregate-review.changes_requested",
      "action": "route-delivery",
      "enabled": true,
      "id": "on.aggregate-review.changes_requested.start.route-delivery"
    },
    {
      "source": "event",
      "event": "implement.failed",
      "action": "troubleshoot",
      "enabled": true,
      "id": "on.implement.failed.start.troubleshoot"
    },
    {
      "source": "event",
      "event": "verify.failed",
      "action": "troubleshoot",
      "enabled": true,
      "id": "on.verify.failed.start.troubleshoot"
    },
    {
      "source": "event",
      "event": "troubleshoot.ready",
      "action": "deploy",
      "enabled": true,
      "id": "on.troubleshoot.ready.start.deploy"
    },
    {
      "source": "trigger",
      "trigger": "review_gate_approved",
      "action": "document",
      "enabled": true,
      "id": "on.trigger.review_gate_approved.start.document"
    },
    {
      "source": "event",
      "event": "document.ready",
      "action": "prepare-deploy",
      "enabled": true,
      "id": "on.document.ready.start.prepare-deploy"
    },
    {
      "source": "event",
      "event": "prepare-deploy.ready",
      "action": "review-release",
      "enabled": true,
      "id": "on.prepare-deploy.ready.start.review-release"
    },
    {
      "source": "event",
      "event": "review-release.changes_requested",
      "action": "prepare-deploy",
      "enabled": true,
      "id": "on.review-release.changes_requested.start.prepare-deploy"
    },
    {
      "source": "trigger",
      "trigger": "release_approved",
      "action": "deploy",
      "enabled": true,
      "id": "on.trigger.release_approved.start.deploy"
    },
    {
      "source": "trigger",
      "trigger": "production_deploy_approved",
      "action": "deploy",
      "enabled": true,
      "id": "on.trigger.production_deploy_approved.start.deploy"
    },
    {
      "source": "event",
      "event": "deploy.deployed",
      "action": "document-release",
      "enabled": true,
      "id": "on.deploy.deployed.start.document-release"
    },
    {
      "source": "event",
      "event": "deploy.failed",
      "action": "troubleshoot",
      "enabled": true,
      "id": "on.deploy.failed.start.troubleshoot"
    },
    {
      "source": "trigger",
      "trigger": "ci_or_validation_failed",
      "action": "troubleshoot",
      "enabled": true,
      "id": "on.trigger.ci_or_validation_failed.start.troubleshoot"
    },
    {
      "source": "trigger",
      "trigger": "incident_reported",
      "action": "triage-incident",
      "enabled": true,
      "id": "on.trigger.incident_reported.start.triage-incident"
    },
    {
      "source": "event",
      "event": "triage-incident.ready",
      "action": "design-release",
      "enabled": true,
      "id": "on.triage-incident.ready.start.design-release"
    },
    {
      "source": "event",
      "event": "design-roadmap.ready",
      "action": "review-intent",
      "enabled": true,
      "id": "on.design-roadmap.ready.start.review-intent"
    },
    {
      "source": "event",
      "event": "route-project.blocked",
      "action": "aggregate-review",
      "enabled": true,
      "id": "on.route-project.blocked.start.aggregate-review"
    }
  ],
  "workflows": [
    {
      "id": "intent-to-roadmap",
      "title": "Intent to roadmap",
      "steps": [
        "on.trigger.intent_changed.start.route-project",
        "on.route-project.ready.start.analyze-intent",
        "on.analyze-intent.ready.start.design-roadmap",
        "on.design-roadmap.ready.start.review-intent",
        "on.review-intent.changes_requested.start.analyze-intent",
        "on.route-project.blocked.start.aggregate-review"
      ]
    },
    {
      "id": "roadmap-to-implementation-plan",
      "title": "Roadmap to implementation plan",
      "steps": [
        "on.trigger.roadmap_approved.start.design-release",
        "on.trigger.roadmap_approved.start.design-ui",
        "on.design-release.ready.start.review-feasibility",
        "on.design-ui.ready.start.review-feasibility",
        "on.review-feasibility.changes_requested.start.design-release",
        "on.review-feasibility.changes_requested.start.design-ui"
      ]
    },
    {
      "id": "implementation-loop",
      "title": "Implementation loop",
      "steps": [
        "on.trigger.implementation_plan_approved.start.route-delivery",
        "on.route-delivery.ready.start.implement",
        "on.implement.ready.start.verify",
        "on.verify.ready.start.review-intent",
        "on.verify.ready.start.review-architect",
        "on.verify.ready.start.review-qa-verification-reviewer",
        "on.verify.ready.start.review-ops",
        "on.review-qa-verification-reviewer.approved.start.aggregate-review",
        "on.review-intent.changes_requested.start.analyze-intent",
        "on.review-architect.changes_requested.start.route-delivery",
        "on.review-qa-verification-reviewer.changes_requested.start.route-delivery",
        "on.review-ops.changes_requested.start.route-delivery",
        "on.aggregate-review.changes_requested.start.route-delivery",
        "on.implement.failed.start.troubleshoot",
        "on.verify.failed.start.troubleshoot",
        "on.troubleshoot.ready.start.deploy"
      ]
    },
    {
      "id": "documentation-and-release-preparation",
      "title": "Documentation and release preparation",
      "steps": [
        "on.trigger.review_gate_approved.start.document",
        "on.document.ready.start.prepare-deploy",
        "on.prepare-deploy.ready.start.review-release",
        "on.review-release.changes_requested.start.prepare-deploy"
      ]
    },
    {
      "id": "deploy",
      "title": "Deploy",
      "steps": [
        "on.trigger.production_deploy_approved.start.deploy",
        "on.deploy.deployed.start.document-release",
        "on.deploy.failed.start.troubleshoot",
        "on.troubleshoot.ready.start.deploy"
      ]
    },
    {
      "id": "incident-and-failure-recovery",
      "title": "Incident and failure recovery",
      "steps": [
        "on.trigger.ci_or_validation_failed.start.troubleshoot",
        "on.troubleshoot.ready.start.deploy",
        "on.trigger.incident_reported.start.triage-incident",
        "on.triage-incident.ready.start.design-release"
      ]
    }
  ],
  "runtimes": [
    {
      "id": "runtime-codex",
      "title": "codex-cli",
      "command": "codex",
      "args": []
    }
  ]
}
