            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Johda saman scopen behavior- ja DESIGN-lähteistä actorit, journeyt, näkymät ja success/empty/loading/error/permission-tilat `.ballet/outputs/ux-information-architecture.yaml`:iin. Älä lainaa toisen scopen DESIGN.md:tä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "ux-information-architecture",
          "on": {
            "ready": {
              "action": "goto",
              "target": "test-strategy"
            },
            "approved": {
              "action": "terminate",
              "status": "blocked"
            },
            "changes-requested": {
              "action": "terminate",
              "status": "blocked"
            },
            "needs_input": {
              "action": "goto",
              "target": "source-decision-gate",
              "input": "signal"
            },
            "blocked": {
              "action": "terminate",
              "status": "blocked"
            },
            "failed": {
              "action": "retry",
              "policy": {
                "maxAttempts": 1,
                "onExhausted": {
                  "action": "terminate",
                  "status": "failed"
                },
                "when": {
                  "failureClassification": "transient"
                }
              }
            }
          },
          "type": "agent",
