{
  "version": 1,
  "triggers": [
    {
      "id": "plan_approved",
      "description": "Plan approved"
    }
  ],
  "actions": [
    {
      "id": "implement",
      "description": "Implement an approved plan.",
      "outputIds": [
        "completed",
        "failed",
        "blocked"
      ]
    },
    {
      "id": "review",
      "description": "Review implementation output.",
      "outputIds": [
        "accepted",
        "rejected",
        "failed"
      ]
    },
    {
      "id": "test",
      "description": "Test implementation ja paljon tekstiä tämän perään.",
      "outputIds": [
        "completed",
        "failed",
        "blocked"
      ]
    },
    {
      "id": "plan",
      "description": "Plan incomplete specs.",
      "outputIds": [
        "completed",
        "failed",
        "blocked"
      ]
    }
  ],
  "outputs": [
    {
      "id": "completed",
      "description": "Agent work completed."
    },
    {
      "id": "failed",
      "description": "Agent work failed."
    },
    {
      "id": "blocked",
      "description": "Agent work ended up in a blocked state."
    },
    {
      "id": "accepted",
      "description": "Agent work accepted."
    },
    {
      "id": "rejected",
      "description": "Agent work rejected."
    }
  ],
  "policies": [
    {
      "id": "on.trigger.plan_approved.then.developer.start.implement",
      "source": "trigger",
      "trigger": "plan_approved",
      "agent": "developer",
      "action": "implement",
      "enabled": true
    },
    {
      "id": "on.developer.implement.completed.then.architect.start.review",
      "source": "event",
      "event": "developer.implement.completed",
      "agent": "architect",
      "action": "review",
      "enabled": true
    },
    {
      "id": "on.developer.implement.completed.then.qa-verification-reviewer.start.review",
      "source": "event",
      "event": "developer.implement.completed",
      "agent": "qa-verification-reviewer",
      "action": "review",
      "enabled": true
    },
    {
      "id": "on.qa.test.completed.then.ux.start.test",
      "source": "event",
      "event": "qa.test.completed",
      "agent": "ux",
      "action": "test",
      "enabled": true
    },
    {
      "id": "on.architect.review.rejected.then.developer.start.implement",
      "source": "event",
      "event": "architect.review.rejected",
      "agent": "developer",
      "action": "implement",
      "enabled": true
    },
    {
      "id": "on.architect.review.accepted.then.qa.start.test",
      "source": "event",
      "event": "architect.review.accepted",
      "agent": "qa",
      "action": "test",
      "enabled": true
    }
  ],
  "workflows": [
    {
      "id": "plan-implement-review",
      "title": "Plan, implement, review",
      "steps": [
        "on.trigger.plan_approved.then.developer.start.implement",
        "on.developer.implement.completed.then.architect.start.review",
        "on.architect.review.rejected.then.developer.start.implement",
        "on.architect.review.accepted.then.qa.start.test"
      ]
    }
  ],
  "runtimes": [
    {
      "id": "runtime-codex",
      "title": "codex-cli",
      "command": "codex",
      "args": []
    }
  ]
}
