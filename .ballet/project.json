{
  "version": 8,
  "agents": {
    "acceptance-test-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "architecture-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "implementation-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "implementation-plan-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "milestone-issues-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "blueprint-verifier-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "release-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "roadmap-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "test-plan-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "ui-design-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    }
  },
  "loops": [
    {
      "id": "blueprint-design",
      "start": "source-inventory",
      "nodes": [
        {
          "description": "Inventoi `.ballet/source-plane.yaml`:n eksplisiittisen `blueprint_scope`-valinnan kaikki ihmisen omistamat lähteet ja kirjoita deterministinen `.ballet/outputs/source-snapshot.yaml`, joka sitoutuu Git HEAD SHA:han, source-statuksiin, polkuihin ja raw-byte SHA-256 -hasheihin.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "source-inventory",
          "on": {
            "ready": "source-validation",
            "approved": "source-validation",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Tarkista olemassa oleva snapshot täysin read-only-moodissa projektin source plane- ja governance-sääntöjä vasten. Todista ID:iden, statusten, viitteiden, scopejen, polkujen, Git SHA:n ja hashien eheys muuttamatta tai korjaamatta snapshotia ennen yhtäkään johdettua blueprint-artifactia.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "source-validation",
          "on": {
            "ready": "gap-and-conflict-audit",
            "approved": "gap-and-conflict-audit",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Kirjoita `.ballet/outputs/specification-gaps.yaml` ja luo `.ballet/outputs/decision-requests.yaml` vain, jos puuttuva, ristiriitainen, epäselvä tai hyväksymätön WHAT/WHY-päätös blokkaa työn. Älä muuta puutetta oletukseksi.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "gap-and-conflict-audit",
          "on": {
            "ready": "roadmap",
            "approved": "roadmap",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Ratkaise decision request päivittämällä ja hyväksymällä ihmisen omistama lähde. Gate-vastaus ei itsessään ole uusi source authority. Approved käynnistää uuden inventoinnin ja snapshotin; rejected päättää Runin blokattuna.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "source-decision-gate",
          "on": {
            "approved": "source-inventory",
            "rejected": "blocked"
          },
          "type": "human"
        },
        {
          "description": "Johda validoiduista hyväksytyistä lähteistä vertikaaliset toimitusslicet `.ballet/outputs/roadmap.yaml`:iin. Säilytä source- ja acceptance-viitteet, riippuvuudet, riskit ja validointipisteet.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "roadmap",
          "on": {
            "ready": "domain-map",
            "approved": "domain-map",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Johda source-backed domainit, vastuut, omistajuudet ja suhteet `.ballet/outputs/domain-map.yaml`:iin ilman uutta tuote-, alusta- tai data-päätöstä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "domain-map",
          "on": {
            "ready": "c4-context-container",
            "approved": "c4-context-container",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Johda domain- ja system context sekä C4 context/container `.ballet/outputs/c4-context-container.yaml`:iin. Jätä teknologia nulliksi, ellei saman scopen hyväksytty lähde päätä sitä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "c4-context-container",
          "on": {
            "ready": "quality-scenarios",
            "approved": "quality-scenarios",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Muunna vain hyväksytyt quality policy -vaatimukset mitattaviksi `.ballet/outputs/quality-scenarios.yaml`-skenaarioiksi. Puuttuva raja-arvo on päätöspyyntö, ei oletus.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "quality-scenarios",
          "on": {
            "ready": "threat-model",
            "approved": "threat-model",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Johda assetit, trust boundaryt, uhkat, lähdepohjaiset mitigoinnit ja residual riskit `.ballet/outputs/threat-model.yaml`:iin ilman live-probausta, credentialeja tai riskin hyväksymistä ihmisen puolesta.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "threat-model",
          "on": {
            "ready": "ux-information-architecture",
            "approved": "ux-information-architecture",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Johda saman scopen behavior- ja DESIGN-lähteistä actorit, journeyt, näkymät ja success/empty/loading/error/permission-tilat `.ballet/outputs/ux-information-architecture.yaml`:iin. Älä lainaa toisen scopen DESIGN.md:tä.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "ux-information-architecture",
          "on": {
            "ready": "test-strategy",
            "approved": "test-strategy",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "ui-design-agent"
        },
        {
          "description": "Määrittele source-, acceptance-, quality- ja threat-viitteisiin sidottu blueprintin testistrategia `.ballet/outputs/test-strategy.yaml`:iin.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "test-strategy",
          "on": {
            "ready": "traceability",
            "approved": "traceability",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "architecture-agent"
        },
        {
          "description": "Rakenna source → artifact → acceptance → test -ketju `.ballet/outputs/traceability-manifest.yaml`:iin ja jätä todellinen uncovered coverage näkyväksi.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "traceability",
          "on": {
            "ready": "independent-blueprint-verifier",
            "approved": "independent-blueprint-verifier",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "description": "Tarkista kaikki lähteet ja artifactit suoraan levyltä riippumattomana kirjoittajista. Kirjoita `.ballet/outputs/blueprint-review.yaml` ja vasta hyväksytyn review'n jälkeen `.ballet/outputs/blueprint-gate-packet.yaml`, joka sitoutuu source SHA:han, artifact-hasheihin, oletuksiin, avoimiin päätöksiin, riskeihin, coverageen ja toteuttamattomiin ulkoisiin toimiin.",
          "nodeStyle": "sol",
          "nodeSize": "large",
          "id": "independent-blueprint-verifier",
          "on": {
            "ready": "blueprint-gate",
            "approved": "blueprint-gate",
            "changes-requested": { "repair": "source-inventory" },
            "needs_input": { "human": "source-decision-gate" },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "blueprint-verifier-agent"
        },
        {
          "description": "Hyväksy riippumattomasti verifioitu `.ballet/outputs/blueprint-gate-packet.yaml` juuri sen source SHA:lla ja artifact-hasheilla. Approved-vastauksessa on oltava milestone_id, canonical blueprint_gate_packet -polku, paketin SHA-256 ja source_sha; paketin ulkoiset toimet jäävät not_executed-tilaan.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "blueprint-gate",
          "on": {
            "approved": {
              "loop": "milestone-planning"
            },
            "rejected": "source-inventory"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    },
    {
      "id": "milestone-planning",
      "start": "plan-milestone-issues",
      "nodes": [
        {
          "description": "Varmista human handoffin blueprint-paketin polku, SHA-256, source SHA ja kaikki paketin artifact-hashit. Johda hyväksytystä roadmap-slicestä paikallinen `milestone-manifest.yaml` ja `issue-drafts.yaml`; issue-luonnokset pysyvät draft_only-tilassa eikä GitHubiin kirjoiteta.",
          "nodeStyle": "luna",
          "nodeSize": "medium",
          "id": "plan-milestone-issues",
          "on": {
            "ready": "implementation-plan",
            "approved": "implementation-plan",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "milestone-issues-agent"
        },
        {
          "description": "Laadi valitulle milestonelle päätöksistä johdettu `.ballet/outputs/milestones/<milestone-id>/implementation-plan.yaml`, jossa jokainen vaihe jäljittyy lähteisiin, artifactteihin, acceptance-kriteereihin ja testeihin.",
          "nodeStyle": "luna",
          "nodeSize": "medium",
          "id": "implementation-plan",
          "on": {
            "ready": "test-plan",
            "approved": "test-plan",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "implementation-plan-agent"
        },
        {
          "description": "Määrittele milestonen unit-, integration-, contract-, UI-, acceptance-, security- ja release-verifioinnit `.ballet/outputs/milestones/<milestone-id>/test-plan.yaml`:iin.",
          "nodeStyle": "luna",
          "nodeSize": "medium",
          "id": "test-plan",
          "on": {
            "ready": "milestone-gate",
            "approved": "milestone-gate",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "test-plan-agent"
        },
        {
          "description": "Hyväksy hashattuun blueprint-pakettiin sidottu milestone manifest, vain paikalliset issue-luonnokset, toteutussuunnitelma ja testisuunnitelma toteutuksen lähtökohdaksi.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "milestone-gate",
          "on": {
            "approved": {
              "loop": "milestone-delivery"
            },
            "rejected": "plan-milestone-issues"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    },
    {
      "id": "milestone-delivery",
      "start": "implement-milestone",
      "nodes": [
        {
          "description": "Toteuta hyväksytyn milestonen kaikki rajatut muutokset ja testit `milestone-manifest.yaml`:n, `issue-drafts.yaml`:n, `implementation-plan.yaml`:n, `test-plan.yaml`:n ja blueprint-artifacttien mukaisesti.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "implement-milestone",
          "on": {
            "ready": "run-acceptance-tests",
            "approved": "run-acceptance-tests",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "implementation-agent"
        },
        {
          "description": "Aja `test-plan.yaml`:n hyväksyntätarkistukset riippumattomasti, tarkasta diff ja kirjoita `.ballet/outputs/milestones/<milestone-id>/acceptance-evidence.yaml` sekä `staging-report.yaml` muuttamatta toteutusta.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "run-acceptance-tests",
          "on": {
            "ready": "implementation-gate",
            "approved": "implementation-gate",
            "changes-requested": { "repair": "implement-milestone" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "acceptance-test-agent"
        },
        {
          "description": "Hyväksy milestonen toteutus ja acceptance-evidenssi julkaistavaksi CI/CD-ketjun kautta.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "implementation-gate",
          "on": {
            "approved": {
              "loop": "release-validation"
            },
            "rejected": "implement-milestone"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    },
    {
      "id": "release-validation",
      "start": "make-git-release",
      "nodes": [
        {
          "description": "Tarkista implementation-gate ja hyväksytty release contract ennen ulkoista kirjoitusta. Muodosta vain projektin määrittelemä Git-release ja aloita `.ballet/outputs/releases/<version>/release-manifest.yaml` evidensseineen.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "make-git-release",
          "on": {
            "ready": "deploy-release",
            "approved": "deploy-release",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "release-agent"
        },
        {
          "description": "Käynnistä vain hyväksytyn release contractin ja olemassa olevan CI/CD-sopimuksen sallima deploy. Kirjaa kaikki ulkoiset toimet ja workflow-evidenssi samaan `release-manifest.yaml`:iin.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "deploy-release",
          "on": {
            "ready": "verify-release",
            "approved": "verify-release",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "release-agent"
        },
        {
          "description": "Verifioi deploy health-, smoke-, acceptance- ja observability-checkeillä sekä kirjaa tulokset, hashit ja mahdollinen rollback `release-manifest.yaml`:iin.",
          "nodeStyle": "terra",
          "nodeSize": "medium",
          "id": "verify-release",
          "on": {
            "ready": "release-gate",
            "approved": "release-gate",
            "changes-requested": { "terminate": "blocked" },
            "needs_input": { "wait": true },
            "blocked": { "terminal": "blocked" },
            "failed": { "terminal": "failed", "retry": { "when": "transient", "limit": 1 } }
          },
          "type": "agent",
          "agentId": "release-agent"
        },
        {
          "description": "Tarkasta release-, deploy- ja verifiointievidenssi. Rejection palauttaa verifiointiin eikä luo uutta Git-tagia.",
          "nodeStyle": "luna",
          "nodeSize": "tiny",
          "id": "release-gate",
          "on": {
            "approved": "completed",
            "rejected": "verify-release"
          },
          "type": "human"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "completed",
          "type": "completed"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "blocked",
          "type": "blocked"
        },
        {
          "description": "",
          "nodeStyle": "flat",
          "nodeSize": "tiny",
          "id": "failed",
          "type": "failed"
        }
      ]
    }
  ]
}
