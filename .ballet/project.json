        "on.challenge-technical-plan.approved.start.technical-plan-gate",
        "on.technical-plan-gate.changes_requested.start.create-technical-plan",
        "on.challenge-technical-plan.changes_requested.start.create-technical-plan",
        "on.create-technical-plan.blocked.start.done"
      ]
    },
    {
      "id": "technical-plan-gate.approved.loop",
