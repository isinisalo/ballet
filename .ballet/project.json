{
  "version": 1,
  "triggers": [
    {
      "id": "adr_goals_changed",
      "description": "ADR or GOALS changed. Starts Gate 1 planning by producing Project Brief evidence."
    },
    {
      "id": "project_brief_approved",
      "description": "Gate 1: Human approved Project Brief. Roadmap planning may start."
    },
    {
      "id": "roadmap_approved",
      "description": "Gate 2: Human approved Roadmap. UI design planning may start."
    },
    {
      "id": "ui_design_approved",
      "description": "Gate 3: Human approved UI Design. Technical planning may start."
    },
    {
      "id": "technical_plan_approved",
      "description": "Gate 4: Human approved Technical Plan. Milestone planning may start."
    },
    {
      "id": "milestones_approved",
      "description": "Gate 5: Human approved Milestones. Task specification may start."
    },
    {
      "id": "task_specs_approved",
      "description": "Gate 6: Human approved Task Specs. Implementation may start."
    },
    {
      "id": "code_approved",
      "description": "Gate 7: Human approved code after review and tests. Dev deployment may start."
    },
    {
      "id": "ci_or_validation_failed",
      "description": "CI, tests, code review, deployment, or validation failed and needs failure classification."
    }
  ],
  "actions": [
    {
      "id": "create-project-brief",
      "description": "Create Project Brief from accepted ADRs and approved GOALS.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "brief-agent"
      ]
    },
    {
      "id": "challenge-project-brief",
      "description": "Challenge Project Brief against ADRs, GOALS, constraints, assumptions, and traceability.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-roadmap",
      "description": "Create traceable delivery roadmap from approved Project Brief.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "roadmap-agent"
      ]
    },
    {
      "id": "challenge-roadmap",
      "description": "Challenge roadmap for value order, risk order, dependencies, and ADR/GOALS alignment.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-ui-design",
      "description": "Create UI/UX design plan from approved Roadmap.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "ui-design-agent"
      ]
    },
    {
      "id": "challenge-ui-design",
      "description": "Challenge UI design for goal fit, states, accessibility, consistency, and implementation cost.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-technical-plan",
      "description": "Create implementation-ready Technical Plan from ADRs, Roadmap, and approved UI Design.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "technical-plan-agent"
      ]
    },
    {
      "id": "challenge-technical-plan",
      "description": "Challenge Technical Plan for architecture, data, APIs, security, testability, deployability, and rollback.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-milestones",
      "description": "Create validated milestones from approved Technical Plan and Roadmap.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "milestone-task-agent"
      ]
    },
    {
      "id": "challenge-milestones",
      "description": "Challenge milestones for scope, dependency order, validation method, and increment value.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-task-specs",
      "description": "Create atomic task specifications from approved milestones.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "milestone-task-agent"
      ]
    },
    {
      "id": "challenge-task-specs",
      "description": "Challenge task specs for atomicity, acceptance criteria, testability, dependencies, and traceability.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "implement-task",
      "description": "Implement only the approved task spec as the smallest safe code change.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "implementation-agent"
      ]
    },
    {
      "id": "run-tests",
      "description": "Run or assess required tests, build, lint, and acceptance evidence.",
      "outputIds": [
        "ready",
        "failed"
      ],
      "agentIds": [
        "review-test-agent"
      ]
    },
    {
      "id": "review-code",
      "description": "Review code against task spec, ADRs, GOALS, tests, security, and scope boundaries.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "review-test-agent"
      ]
    },
    {
      "id": "prepare-dev-deployment",
      "description": "Check dev deployment readiness: artifact, config, migrations, rollback, and validation plan.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "deploy-to-dev",
      "description": "Deploy the approved build to the dev environment.",
      "outputIds": [
        "ready",
        "failed"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "validate-dev-deployment",
      "description": "Validate dev deployment with smoke tests, acceptance checks, logs, metrics, and traces.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "classify-failure",
      "description": "Classify failed implementation, test, review, or deployment evidence and produce the smallest safe correction route.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "failure-router-agent"
      ]
    },
    {
      "id": "done",
      "description": "Stop this workflow segment and wait for the next human gate trigger, or finish if Gate 8 is complete.",
      "outputIds": [],
      "agentIds": []
    }
  ],
  "outputs": [
    {
      "id": "ready"
    },
    {
      "id": "approved"
    },
    {
      "id": "changes_requested"
    },
    {
      "id": "blocked"
    },
    {
      "id": "failed"
    }
  ],
  "policies": [
    {
      "id": "p01.on.adr-goals-changed.create-project-brief",
      "source": "trigger",
      "trigger": "adr_goals_changed",
      "action": "create-project-brief",
      "enabled": true
    },
    {
      "id": "p02.on.project-brief-ready.challenge-project-brief",
      "source": "event",
      "event": "create-project-brief.ready",
      "action": "challenge-project-brief",
      "enabled": true
    },
    {
      "id": "p03.on.project-brief-rework.create-project-brief",
      "source": "event",
      "event": "challenge-project-brief.changes_requested",
      "action": "create-project-brief",
      "enabled": true
    },
    {
      "id": "p04.on.project-brief-approved.done",
      "source": "event",
      "event": "challenge-project-brief.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p05.on.project-brief-approved.create-roadmap",
      "source": "trigger",
      "trigger": "project_brief_approved",
      "action": "create-roadmap",
      "enabled": true
    },
    {
      "id": "p06.on.roadmap-ready.challenge-roadmap",
      "source": "event",
      "event": "create-roadmap.ready",
      "action": "challenge-roadmap",
      "enabled": true
    },
    {
      "id": "p07.on.roadmap-rework.create-roadmap",
      "source": "event",
      "event": "challenge-roadmap.changes_requested",
      "action": "create-roadmap",
      "enabled": true
    },
    {
      "id": "p08.on.roadmap-approved.done",
      "source": "event",
      "event": "challenge-roadmap.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p09.on.roadmap-approved.create-ui-design",
      "source": "trigger",
      "trigger": "roadmap_approved",
      "action": "create-ui-design",
      "enabled": true
    },
    {
      "id": "p10.on.ui-design-ready.challenge-ui-design",
      "source": "event",
      "event": "create-ui-design.ready",
      "action": "challenge-ui-design",
      "enabled": true
    },
    {
      "id": "p11.on.ui-design-rework.create-ui-design",
      "source": "event",
      "event": "challenge-ui-design.changes_requested",
      "action": "create-ui-design",
      "enabled": true
    },
    {
      "id": "p12.on.ui-design-approved.done",
      "source": "event",
      "event": "challenge-ui-design.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p13.on.ui-design-approved.create-technical-plan",
      "source": "trigger",
      "trigger": "ui_design_approved",
      "action": "create-technical-plan",
      "enabled": true
    },
    {
      "id": "p14.on.technical-plan-ready.challenge-technical-plan",
      "source": "event",
      "event": "create-technical-plan.ready",
      "action": "challenge-technical-plan",
      "enabled": true
    },
    {
      "id": "p15.on.technical-plan-rework.create-technical-plan",
      "source": "event",
      "event": "challenge-technical-plan.changes_requested",
      "action": "create-technical-plan",
      "enabled": true
    },
    {
      "id": "p16.on.technical-plan-approved.done",
      "source": "event",
      "event": "challenge-technical-plan.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p17.on.technical-plan-approved.create-milestones",
      "source": "trigger",
      "trigger": "technical_plan_approved",
      "action": "create-milestones",
      "enabled": true
    },
    {
      "id": "p18.on.milestones-ready.challenge-milestones",
      "source": "event",
      "event": "create-milestones.ready",
      "action": "challenge-milestones",
      "enabled": true
    },
    {
      "id": "p19.on.milestones-rework.create-milestones",
      "source": "event",
      "event": "challenge-milestones.changes_requested",
      "action": "create-milestones",
      "enabled": true
    },
    {
      "id": "p20.on.milestones-approved.done",
      "source": "event",
      "event": "challenge-milestones.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p21.on.milestones-approved.create-task-specs",
      "source": "trigger",
      "trigger": "milestones_approved",
      "action": "create-task-specs",
      "enabled": true
    },
    {
      "id": "p22.on.task-specs-ready.challenge-task-specs",
      "source": "event",
      "event": "create-task-specs.ready",
      "action": "challenge-task-specs",
      "enabled": true
    },
    {
      "id": "p23.on.task-specs-rework.create-task-specs",
      "source": "event",
      "event": "challenge-task-specs.changes_requested",
      "action": "create-task-specs",
      "enabled": true
    },
    {
      "id": "p24.on.task-specs-approved.done",
      "source": "event",
      "event": "challenge-task-specs.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p25.on.task-specs-approved.implement-task",
      "source": "trigger",
      "trigger": "task_specs_approved",
      "action": "implement-task",
      "enabled": true
    },
    {
      "id": "p26.on.implementation-ready.run-tests",
      "source": "event",
      "event": "implement-task.ready",
      "action": "run-tests",
      "enabled": true
    },
    {
      "id": "p27.on.implementation-blocked.classify-failure",
      "source": "event",
      "event": "implement-task.blocked",
      "action": "classify-failure",
      "enabled": true
    },
    {
      "id": "p28.on.tests-ready.review-code",
      "source": "event",
      "event": "run-tests.ready",
      "action": "review-code",
      "enabled": true
    },
    {
      "id": "p29.on.tests-failed.classify-failure",
      "source": "event",
      "event": "run-tests.failed",
      "action": "classify-failure",
      "enabled": true
    },
    {
      "id": "p30.on.code-review-rework.implement-task",
      "source": "event",
      "event": "review-code.changes_requested",
      "action": "implement-task",
      "enabled": true
    },
    {
      "id": "p31.on.code-review-approved.done",
      "source": "event",
      "event": "review-code.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p32.on.code-approved.prepare-dev-deployment",
      "source": "trigger",
      "trigger": "code_approved",
      "action": "prepare-dev-deployment",
      "enabled": true
    },
    {
      "id": "p33.on.dev-deployment-ready.deploy-to-dev",
      "source": "event",
      "event": "prepare-dev-deployment.ready",
      "action": "deploy-to-dev",
      "enabled": true
    },
    {
      "id": "p34.on.dev-deployment-blocked.classify-failure",
      "source": "event",
      "event": "prepare-dev-deployment.blocked",
      "action": "classify-failure",
      "enabled": true
    },
    {
      "id": "p35.on.dev-deploy-ready.validate-dev-deployment",
      "source": "event",
      "event": "deploy-to-dev.ready",
      "action": "validate-dev-deployment",
      "enabled": true
    },
    {
      "id": "p36.on.dev-deploy-failed.classify-failure",
      "source": "event",
      "event": "deploy-to-dev.failed",
      "action": "classify-failure",
      "enabled": true
    },
    {
      "id": "p37.on.dev-validation-rework.prepare-dev-deployment",
      "source": "event",
      "event": "validate-dev-deployment.changes_requested",
      "action": "prepare-dev-deployment",
      "enabled": true
    },
    {
      "id": "p38.on.dev-validation-approved.done",
      "source": "event",
      "event": "validate-dev-deployment.approved",
      "action": "done",
      "enabled": true
    },
    {
      "id": "p39.on.ci-or-validation-failed.classify-failure",
      "source": "trigger",
      "trigger": "ci_or_validation_failed",
      "action": "classify-failure",
      "enabled": true
    },
    {
      "id": "p40.on.failure-route-ready.implement-task",
      "source": "event",
      "event": "classify-failure.ready",
      "action": "implement-task",
      "enabled": true
    },
    {
      "id": "p41.on.failure-route-blocked.done",
      "source": "event",
      "event": "classify-failure.blocked",
      "action": "done",
      "enabled": true
    }
  ],
  "workflows": [
    {
      "id": "brief-loop",
      "title": "1. Brief loop",
      "steps": [
        "p01.on.adr-goals-changed.create-project-brief",
        "p02.on.project-brief-ready.challenge-project-brief",
        "p03.on.project-brief-rework.create-project-brief",
        "p04.on.project-brief-approved.done"
      ]
    },
    {
      "id": "roadmap-loop",
      "title": "2. Roadmap loop",
      "steps": [
        "p05.on.project-brief-approved.create-roadmap",
        "p06.on.roadmap-ready.challenge-roadmap",
        "p07.on.roadmap-rework.create-roadmap",
        "p08.on.roadmap-approved.done"
      ]
    },
    {
      "id": "ui-design-loop",
      "title": "3. UI design loop",
      "steps": [
        "p09.on.roadmap-approved.create-ui-design",
        "p10.on.ui-design-ready.challenge-ui-design",
        "p11.on.ui-design-rework.create-ui-design",
        "p12.on.ui-design-approved.done"
      ]
    },
    {
      "id": "technical-planning-loop",
      "title": "4. Technical planning loop",
      "steps": [
        "p13.on.ui-design-approved.create-technical-plan",
        "p14.on.technical-plan-ready.challenge-technical-plan",
        "p15.on.technical-plan-rework.create-technical-plan",
        "p16.on.technical-plan-approved.done"
      ]
    },
    {
      "id": "milestone-task-spec-loop",
      "title": "5. Milestone + task spec loop",
      "steps": [
        "p17.on.technical-plan-approved.create-milestones",
        "p18.on.milestones-ready.challenge-milestones",
        "p19.on.milestones-rework.create-milestones",
        "p20.on.milestones-approved.done",
        "p21.on.milestones-approved.create-task-specs",
        "p22.on.task-specs-ready.challenge-task-specs",
        "p23.on.task-specs-rework.create-task-specs",
        "p24.on.task-specs-approved.done"
      ]
    },
    {
      "id": "implementation-review-test-loop",
      "title": "6. Implementation + review + test loop",
      "steps": [
        "p25.on.task-specs-approved.implement-task",
        "p26.on.implementation-ready.run-tests",
        "p27.on.implementation-blocked.classify-failure",
        "p28.on.tests-ready.review-code",
        "p29.on.tests-failed.classify-failure",
        "p30.on.code-review-rework.implement-task",
        "p31.on.code-review-approved.done",
        "p39.on.ci-or-validation-failed.classify-failure",
        "p40.on.failure-route-ready.implement-task",
        "p41.on.failure-route-blocked.done"
      ]
    },
    {
      "id": "dev-deploy-validation-loop",
      "title": "7. Dev deploy + validation loop",
      "steps": [
        "p32.on.code-approved.prepare-dev-deployment",
        "p33.on.dev-deployment-ready.deploy-to-dev",
        "p34.on.dev-deployment-blocked.classify-failure",
        "p35.on.dev-deploy-ready.validate-dev-deployment",
        "p36.on.dev-deploy-failed.classify-failure",
        "p37.on.dev-validation-rework.prepare-dev-deployment",
        "p38.on.dev-validation-approved.done",
        "p39.on.ci-or-validation-failed.classify-failure",
        "p40.on.failure-route-ready.implement-task",
        "p41.on.failure-route-blocked.done"
      ]
    }
  ],
  "runtimes": [
    {
      "id": "codex-cli",
      "title": "codex-cli",
      "command": "codex",
      "args": []
    }
  ]
}
