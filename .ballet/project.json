{
  "version": 1,
  "actions": [
    {
      "id": "create-project-brief",
      "description": "Create Project Brief from accepted ADRs and approved GOALS.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "brief-agent"
      ]
    },
    {
      "id": "challenge-project-brief",
      "description": "Challenge Project Brief against ADRs, GOALS, constraints, assumptions, and traceability.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "project-brief-gate",
      "description": "Gate 1: Human approval of the agent-reviewed Project Brief before roadmap planning continues.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [],
      "humanGate": true
    },
    {
      "id": "create-roadmap",
      "description": "Create traceable delivery roadmap from approved Project Brief.",
