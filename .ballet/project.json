    "implementation-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "implementation-plan-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "milestone-issues-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
