        "on.deploy-to-dev.ready.start.validate-dev-deployment",
        "on.deploy-to-dev.failed.start.classify-failure",
        "on.validate-dev-deployment.approved.start.dev-deployment-validation-gate",
        "on.validate-dev-deployment.changes_requested.start.prepare-dev-deployment",
        "on.trigger.dev-deployment-validation-gate.approved.start.done",
        "on.dev-deployment-validation-gate.changes_requested.start.prepare-dev-deployment",
        "on.classify-failure.ready.start.implement-task",
        "on.classify-failure.blocked.start.done"
      ]
    },
    {
      "id": "ci_or_validation_failed.loop",
