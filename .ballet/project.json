{
  "version": 1,
  "triggers": [
    {
      "id": "adr_goals_changed",
      "description": "ADR or GOALS changed. Starts Gate 1 planning by producing Project Brief evidence."
    },
    {
      "id": "project_brief_approved",
      "description": "Gate 1: Human approved Project Brief. Roadmap planning may start."
    },
    {
      "id": "roadmap_approved",
      "description": "Gate 2: Human approved Roadmap. UI design planning may start."
    },
    {
      "id": "ui_design_approved",
      "description": "Gate 3: Human approved UI Design. Technical planning may start."
    },
    {
      "id": "technical_plan_approved",
      "description": "Gate 4: Human approved Technical Plan. Milestone planning may start."
    },
    {
      "id": "milestones_approved",
      "description": "Gate 5: Human approved Milestones. Task specification may start."
    },
    {
      "id": "task_specs_approved",
      "description": "Gate 6: Human approved Task Specs. Implementation may start."
    },
    {
      "id": "code_approved",
      "description": "Gate 7: Human approved code after review and tests. Dev deployment may start."
    },
    {
      "id": "ci_or_validation_failed",
      "description": "CI, tests, code review, deployment, or validation failed and needs failure classification."
    }
  ],
  "actions": [
    {
      "id": "create-project-brief",
      "description": "Create Project Brief from accepted ADRs and approved GOALS.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "brief-agent"
      ]
    },
    {
      "id": "challenge-project-brief",
      "description": "Challenge Project Brief against ADRs, GOALS, constraints, assumptions, and traceability.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-roadmap",
      "description": "Create traceable delivery roadmap from approved Project Brief.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "roadmap-agent"
      ]
    },
    {
      "id": "challenge-roadmap",
      "description": "Challenge roadmap for value order, risk order, dependencies, and ADR/GOALS alignment.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-ui-design",
      "description": "Create UI/UX design plan from approved Roadmap.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "ui-design-agent"
      ]
    },
    {
      "id": "challenge-ui-design",
      "description": "Challenge UI design for goal fit, states, accessibility, consistency, and implementation cost.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-technical-plan",
      "description": "Create implementation-ready Technical Plan from ADRs, Roadmap, and approved UI Design.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "technical-plan-agent"
      ]
    },
    {
      "id": "challenge-technical-plan",
      "description": "Challenge Technical Plan for architecture, data, APIs, security, testability, deployability, and rollback.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-milestones",
      "description": "Create validated milestones from approved Technical Plan and Roadmap.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "milestone-task-agent"
      ]
    },
    {
      "id": "challenge-milestones",
      "description": "Challenge milestones for scope, dependency order, validation method, and increment value.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "create-task-specs",
      "description": "Create atomic task specifications from approved milestones.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "milestone-task-agent"
      ]
    },
    {
      "id": "challenge-task-specs",
      "description": "Challenge task specs for atomicity, acceptance criteria, testability, dependencies, and traceability.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "workflow-critic-agent"
      ]
    },
    {
      "id": "implement-task",
      "description": "Implement only the approved task spec as the smallest safe code change.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "implementation-agent"
      ]
    },
    {
      "id": "run-tests",
      "description": "Run or assess required tests, build, lint, and acceptance evidence.",
      "outputIds": [
        "ready",
        "failed"
      ],
      "agentIds": [
        "review-test-agent"
      ]
    },
    {
      "id": "review-code",
      "description": "Review code against task spec, ADRs, GOALS, tests, security, and scope boundaries.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "review-test-agent"
      ]
    },
    {
      "id": "prepare-dev-deployment",
      "description": "Check dev deployment readiness: artifact, config, migrations, rollback, and validation plan.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "deploy-to-dev",
      "description": "Deploy the approved build to the dev environment.",
      "outputIds": [
        "ready",
        "failed"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "validate-dev-deployment",
      "description": "Validate dev deployment with smoke tests, acceptance checks, logs, metrics, and traces.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "classify-failure",
      "description": "Classify failed implementation, test, review, or deployment evidence and produce the smallest safe correction route.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "failure-router-agent"
      ]
    },
    {
      "id": "done",
      "description": "Stop this workflow segment and wait for the next human gate trigger, or finish if Gate 8 is complete.",
      "outputIds": [],
      "agentIds": []
    }
  ],
  "outputs": [
    {
      "id": "ready"
    },
    {
      "id": "approved"
    },
    {
      "id": "changes_requested"
    },
    {
      "id": "blocked"
    },
    {
      "id": "failed"
    }
  ],
  "outputRoutes": [
    {
      "sourcePolicyId": "on.run-tests.ready.start.review-code",
      "outputId": "approved",
      "target": {
        "type": "trigger",
        "trigger": "code_approved",
        "workflowId": "dev-deploy-validation-loop"
      }
    }
  ],
  "policies": [
    {
      "source": "trigger",
      "trigger": "adr_goals_changed",
      "action": "create-project-brief",
      "enabled": true,
      "id": "on.trigger.adr_goals_changed.start.create-project-brief"
    },
    {
      "source": "event",
      "event": "create-project-brief.ready",
      "action": "challenge-project-brief",
      "enabled": true,
      "id": "on.create-project-brief.ready.start.challenge-project-brief"
    },
    {
      "source": "event",
      "event": "challenge-project-brief.changes_requested",
      "action": "create-project-brief",
      "enabled": true,
      "id": "on.challenge-project-brief.changes_requested.start.create-project-brief"
    },
    {
      "source": "event",
      "event": "challenge-project-brief.approved",
      "action": "done",
      "enabled": true,
      "id": "on.challenge-project-brief.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "project_brief_approved",
      "action": "create-roadmap",
      "enabled": true,
      "id": "on.trigger.project_brief_approved.start.create-roadmap"
    },
    {
      "source": "event",
      "event": "create-roadmap.ready",
      "action": "challenge-roadmap",
      "enabled": true,
      "id": "on.create-roadmap.ready.start.challenge-roadmap"
    },
    {
      "source": "event",
      "event": "challenge-roadmap.changes_requested",
      "action": "create-roadmap",
      "enabled": true,
      "id": "on.challenge-roadmap.changes_requested.start.create-roadmap"
    },
    {
      "source": "event",
      "event": "challenge-roadmap.approved",
      "action": "done",
      "enabled": true,
      "id": "on.challenge-roadmap.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "roadmap_approved",
      "action": "create-ui-design",
      "enabled": true,
      "id": "on.trigger.roadmap_approved.start.create-ui-design"
    },
    {
      "source": "event",
      "event": "create-ui-design.ready",
      "action": "challenge-ui-design",
      "enabled": true,
      "id": "on.create-ui-design.ready.start.challenge-ui-design"
    },
    {
      "source": "event",
      "event": "challenge-ui-design.changes_requested",
      "action": "create-ui-design",
      "enabled": true,
      "id": "on.challenge-ui-design.changes_requested.start.create-ui-design"
    },
    {
      "source": "event",
      "event": "challenge-ui-design.approved",
      "action": "done",
      "enabled": true,
      "id": "on.challenge-ui-design.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "ui_design_approved",
      "action": "create-technical-plan",
      "enabled": true,
      "id": "on.trigger.ui_design_approved.start.create-technical-plan"
    },
    {
      "source": "event",
      "event": "create-technical-plan.ready",
      "action": "challenge-technical-plan",
      "enabled": true,
      "id": "on.create-technical-plan.ready.start.challenge-technical-plan"
    },
    {
      "source": "event",
      "event": "challenge-technical-plan.changes_requested",
      "action": "create-technical-plan",
      "enabled": true,
      "id": "on.challenge-technical-plan.changes_requested.start.create-technical-plan"
    },
    {
      "source": "event",
      "event": "challenge-technical-plan.approved",
      "action": "done",
      "enabled": true,
      "id": "on.challenge-technical-plan.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "technical_plan_approved",
      "action": "create-milestones",
      "enabled": true,
      "id": "on.trigger.technical_plan_approved.start.create-milestones"
    },
    {
      "source": "event",
      "event": "create-milestones.ready",
      "action": "challenge-milestones",
      "enabled": true,
      "id": "on.create-milestones.ready.start.challenge-milestones"
    },
    {
      "source": "event",
      "event": "challenge-milestones.changes_requested",
      "action": "create-milestones",
      "enabled": true,
      "id": "on.challenge-milestones.changes_requested.start.create-milestones"
    },
    {
      "source": "event",
      "event": "challenge-milestones.approved",
      "action": "done",
      "enabled": true,
      "id": "on.challenge-milestones.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "milestones_approved",
      "action": "create-task-specs",
      "enabled": true,
      "id": "on.trigger.milestones_approved.start.create-task-specs"
    },
    {
      "source": "event",
      "event": "create-task-specs.ready",
      "action": "challenge-task-specs",
      "enabled": true,
      "id": "on.create-task-specs.ready.start.challenge-task-specs"
    },
    {
      "source": "event",
      "event": "challenge-task-specs.changes_requested",
      "action": "create-task-specs",
      "enabled": true,
      "id": "on.challenge-task-specs.changes_requested.start.create-task-specs"
    },
    {
      "source": "event",
      "event": "challenge-task-specs.approved",
      "action": "done",
      "enabled": true,
      "id": "on.challenge-task-specs.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "task_specs_approved",
      "action": "implement-task",
      "enabled": true,
      "id": "on.trigger.task_specs_approved.start.implement-task"
    },
    {
      "source": "event",
      "event": "implement-task.ready",
      "action": "run-tests",
      "enabled": true,
      "id": "on.implement-task.ready.start.run-tests"
    },
    {
      "source": "event",
      "event": "implement-task.blocked",
      "action": "classify-failure",
      "enabled": true,
      "id": "on.implement-task.blocked.start.classify-failure"
    },
    {
      "source": "event",
      "event": "run-tests.ready",
      "action": "review-code",
      "enabled": true,
      "id": "on.run-tests.ready.start.review-code"
    },
    {
      "source": "event",
      "event": "run-tests.failed",
      "action": "classify-failure",
      "enabled": true,
      "id": "on.run-tests.failed.start.classify-failure"
    },
    {
      "source": "event",
      "event": "review-code.changes_requested",
      "action": "implement-task",
      "enabled": true,
      "id": "on.review-code.changes_requested.start.implement-task"
    },
    {
      "source": "event",
      "event": "review-code.approved",
      "action": "done",
      "enabled": true,
      "id": "on.review-code.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "code_approved",
      "action": "prepare-dev-deployment",
      "enabled": true,
      "id": "on.trigger.code_approved.start.prepare-dev-deployment"
    },
    {
      "source": "event",
      "event": "prepare-dev-deployment.ready",
      "action": "deploy-to-dev",
      "enabled": true,
      "id": "on.prepare-dev-deployment.ready.start.deploy-to-dev"
    },
    {
      "source": "event",
      "event": "prepare-dev-deployment.blocked",
      "action": "classify-failure",
      "enabled": true,
      "id": "on.prepare-dev-deployment.blocked.start.classify-failure"
    },
    {
      "source": "event",
      "event": "deploy-to-dev.ready",
      "action": "validate-dev-deployment",
      "enabled": true,
      "id": "on.deploy-to-dev.ready.start.validate-dev-deployment"
    },
    {
      "source": "event",
      "event": "deploy-to-dev.failed",
      "action": "classify-failure",
      "enabled": true,
      "id": "on.deploy-to-dev.failed.start.classify-failure"
    },
    {
      "source": "event",
      "event": "validate-dev-deployment.changes_requested",
      "action": "prepare-dev-deployment",
      "enabled": true,
      "id": "on.validate-dev-deployment.changes_requested.start.prepare-dev-deployment"
    },
    {
      "source": "event",
      "event": "validate-dev-deployment.approved",
      "action": "done",
      "enabled": true,
      "id": "on.validate-dev-deployment.approved.start.done"
    },
    {
      "source": "trigger",
      "trigger": "ci_or_validation_failed",
      "action": "classify-failure",
      "enabled": true,
      "id": "on.trigger.ci_or_validation_failed.start.classify-failure"
    },
    {
      "source": "event",
      "event": "classify-failure.ready",
      "action": "implement-task",
      "enabled": true,
      "id": "on.classify-failure.ready.start.implement-task"
    },
    {
      "source": "event",
      "event": "classify-failure.blocked",
      "action": "done",
      "enabled": true,
      "id": "on.classify-failure.blocked.start.done"
    },
    {
      "source": "event",
      "event": "create-ui-design.blocked",
      "action": "create-ui-design",
      "enabled": true,
      "id": "on.create-ui-design.blocked.start.create-ui-design"
    }
  ],
  "workflows": [
    {
      "id": "brief-loop",
      "title": "1. Brief loop",
      "steps": [
        "on.trigger.adr_goals_changed.start.create-project-brief",
        "on.create-project-brief.ready.start.challenge-project-brief",
        "on.challenge-project-brief.changes_requested.start.create-project-brief",
        "on.challenge-project-brief.approved.start.done"
      ]
    },
    {
      "id": "roadmap-loop",
      "title": "2. Roadmap loop",
      "steps": [
        "on.trigger.project_brief_approved.start.create-roadmap",
        "on.create-roadmap.ready.start.challenge-roadmap",
        "on.challenge-roadmap.changes_requested.start.create-roadmap",
        "on.challenge-roadmap.approved.start.done"
      ]
    },
    {
      "id": "ui-design-loop",
      "title": "3. UI design loop",
      "steps": [
        "on.trigger.roadmap_approved.start.create-ui-design",
        "on.create-ui-design.ready.start.challenge-ui-design",
        "on.challenge-ui-design.changes_requested.start.create-ui-design",
        "on.challenge-ui-design.approved.start.done"
      ]
    },
    {
      "id": "technical-planning-loop",
      "title": "4. Technical planning loop",
      "steps": [
        "on.trigger.ui_design_approved.start.create-technical-plan",
        "on.create-technical-plan.ready.start.challenge-technical-plan",
        "on.challenge-technical-plan.changes_requested.start.create-technical-plan",
        "on.challenge-technical-plan.approved.start.done"
      ]
    },
    {
      "id": "milestone-task-spec-loop",
      "title": "5. Milestone + task spec loop",
      "steps": [
        "on.trigger.technical_plan_approved.start.create-milestones",
        "on.create-milestones.ready.start.challenge-milestones",
        "on.challenge-milestones.changes_requested.start.create-milestones",
        "on.challenge-milestones.approved.start.done",
        "on.trigger.milestones_approved.start.create-task-specs",
        "on.create-task-specs.ready.start.challenge-task-specs",
        "on.challenge-task-specs.changes_requested.start.create-task-specs",
        "on.challenge-task-specs.approved.start.done"
      ]
    },
    {
      "id": "implementation-review-test-loop",
      "title": "6. Implementation + review + test loop",
      "steps": [
        "on.trigger.task_specs_approved.start.implement-task",
        "on.implement-task.ready.start.run-tests",
        "on.implement-task.blocked.start.classify-failure",
      "on.run-tests.ready.start.review-code",
      "on.run-tests.failed.start.classify-failure",
      "on.review-code.changes_requested.start.implement-task",
      "on.trigger.ci_or_validation_failed.start.classify-failure",
        "on.classify-failure.ready.start.implement-task",
        "on.classify-failure.blocked.start.done"
      ]
    },
    {
      "id": "dev-deploy-validation-loop",
      "title": "7. Dev deploy + validation loop",
      "steps": [
        "on.trigger.code_approved.start.prepare-dev-deployment",
        "on.prepare-dev-deployment.ready.start.deploy-to-dev",
        "on.prepare-dev-deployment.blocked.start.classify-failure",
        "on.deploy-to-dev.ready.start.validate-dev-deployment",
        "on.deploy-to-dev.failed.start.classify-failure",
        "on.validate-dev-deployment.changes_requested.start.prepare-dev-deployment",
        "on.validate-dev-deployment.approved.start.done",
        "on.trigger.ci_or_validation_failed.start.classify-failure",
        "on.classify-failure.ready.start.implement-task",
        "on.classify-failure.blocked.start.done"
      ]
    }
  ],
  "runtimes": [
    {
      "id": "codex-cli",
      "title": "codex-cli",
      "command": "codex",
      "args": []
    }
  ]
}
