        "ready",
        "failed"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "validate-dev-deployment",
      "description": "Validate dev deployment with smoke tests, acceptance checks, logs, metrics, and traces.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [
        "dev-deploy-agent"
      ]
    },
    {
      "id": "dev-deployment-validation-gate",
      "description": "Gate 8: Human approval of validated dev deployment before the workflow is done.",
      "outputIds": [
        "approved",
        "changes_requested"
      ],
      "agentIds": [],
      "humanGate": true
    },
    {
      "id": "classify-failure",
      "description": "Classify failed implementation, review, test, deployment, or validation evidence and route safe corrections.",
      "outputIds": [
        "ready",
        "blocked"
      ],
      "agentIds": [
        "failure-router-agent"
      ]
    },
    {
      "id": "done",
      "description": "No further workflow action.",
      "outputIds": [],
      "agentIds": []
    }
  ],
