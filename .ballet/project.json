{
  "version": 6,
  "agents": {
    "dev-deploy-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "implementation-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "milestone-task-agent": {
      "provider": "codex",
      "model": "gpt-5.6-luna",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "review-test-agent": {
      "provider": "codex",
      "model": "gpt-5.6-terra",
      "reasoning": "medium",
      "policy": {
        "network": true
      }
    },
    "roadmap-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    },
    "ui-design-agent": {
      "provider": "codex",
      "model": "gpt-5.6-sol",
      "reasoning": "medium",
      "policy": {
        "network": false
      }
    }
  },
  "loops": [
    {
      "id": "delivery-planning",
      "theme": "open-ai",
      "start": "create-roadmap",
      "steps": [
        {
          "id": "create-roadmap",
          "description": "Muodosta hyväksytyistä ADR- ja Goal-dokumenteista arvo-, riski- ja riippuvuusjärjestykseen asetettu roadmap tiedostoon .ballet/outputs/ROADMAP.md.",
          "nodeSize": "large",
          "on": {
            "approved": "create-work-breakdown",
            "rejected": {
              "end": "blocked"
            }
          },
          "type": "agent",
          "agentId": "roadmap-agent"
        },
        {
          "id": "create-work-breakdown",
          "description": "Jaa roadmap milestoneiksi ja atomisiksi task-NNN-tehtäviksi tiedostoihin .ballet/outputs/MILESTONES.md ja .ballet/outputs/TASKS.md.",
          "nodeSize": "small",
          "on": {
            "approved": "planning-gate",
            "rejected": {
              "end": "blocked"
            }
          },
          "type": "agent",
          "agentId": "milestone-task-agent"
        },
        {
          "id": "planning-gate",
          "description": "Hyväksy roadmap, milestonet ja taskit toteutuksen lähtökohdaksi. Rejection-palaute käynnistää suunnittelun uudelleen roadmapista.",
          "nodeSize": "small",
          "on": {
            "approved": {
              "end": "completed"
            },
            "rejected": "create-roadmap"
          },
          "type": "human"
        }
      ]
    },
    {
      "id": "ui-design",
      "theme": "open-ai",
      "start": "design-task-ui",
      "steps": [
        {
          "id": "design-task-ui",
          "description": "Suunnittele yhden Run-inputissa nimetyn task-NNN-tehtävän UI tiedostoon .ballet/outputs/ui/<task-id>.md.",
          "nodeSize": "large",
          "on": {
            "approved": {
              "end": "completed"
            },
            "rejected": {
              "end": "blocked"
            }
          },
          "type": "agent",
          "agentId": "ui-design-agent"
        }
      ]
    },
    {
      "id": "implementation",
      "theme": "open-ai",
      "start": "implement-task",
      "steps": [
        {
          "id": "implement-task",
          "description": "Toteuta täsmälleen yksi Run-inputissa nimetty task-NNN-tehtävä ja sen hyväksymiskriteerit.",
          "nodeSize": "medium",
          "on": {
            "approved": "verify-task",
            "rejected": {
              "end": "blocked"
            }
          },
          "type": "agent",
          "agentId": "implementation-agent"
        },
        {
          "id": "verify-task",
          "description": "Tarkasta taskin scope, diff, testit ja hyväksymiskriteerit riippumattomasti; saman taskin korjaukset palautuvat implementointiin.",
          "nodeSize": "medium",
          "on": {
            "approved": "code-gate",
            "rejected": "implement-task"
          },
          "type": "agent",
          "agentId": "review-test-agent"
        },
        {
          "id": "code-gate",
          "description": "Hyväksy tarkastettu koodi ja valtuuta dev-deployment. Rejection-palaute palauttaa saman taskin implementointiin.",
          "nodeSize": "small",
          "on": {
            "approved": {
              "loop": "dev-deployment"
            },
            "rejected": "implement-task"
          },
          "type": "human"
        }
      ]
    },
    {
      "id": "dev-deployment",
      "theme": "open-ai",
      "start": "deploy-and-validate-dev",
      "steps": [
        {
          "id": "deploy-and-validate-dev",
          "description": "Tarkista valmius, deployaa vain dev-ympäristöön, validoi smoke-, acceptance- ja observability-checkit sekä rollbackaa epäonnistunut julkaisu.",
          "nodeSize": "medium",
          "on": {
            "approved": {
              "end": "completed"
            },
            "rejected": {
              "end": "failed"
            }
          },
          "type": "agent",
          "agentId": "dev-deploy-agent"
        }
      ]
    },
    {
      "id": "timed",
      "theme": "open-ai",
      "start": "schedule-dev-deployment",
      "steps": [
        {
          "id": "schedule-dev-deployment",
          "description": "Käynnistä kehitysympäristön deploymentin validointi arkipäivisin klo 09:00.",
          "nodeSize": "small",
          "type": "scheduled",
          "schedule": {
            "time": "09:00",
            "timeZone": "Europe/Helsinki",
            "kind": "recurring",
            "startsOn": "2026-07-13",
            "cadence": "weekdays"
          },
          "on": {
            "triggered": "deploy-and-validate-dev"
          }
        },
        {
          "id": "deploy-and-validate-dev",
          "description": "Tarkista valmius, deployaa vain dev-ympäristöön, validoi smoke-, acceptance- ja observability-checkit sekä rollbackaa epäonnistunut julkaisu.",
          "nodeSize": "medium",
          "on": {
            "approved": {
              "end": "completed"
            },
            "rejected": {
              "end": "failed"
            }
          },
          "type": "agent",
          "agentId": "dev-deploy-agent"
        }
      ]
    }
  ]
}
