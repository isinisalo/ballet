{
  "version": 1,
  "triggers": [
    {
      "id": "plan_approved",
      "description": "Plan approved"
    }
  ],
  "actions": [
    {
      "id": "implementation",
      "description": "Implement an approved plan."
    },
    {
      "id": "review",
      "description": "Review implementation output."
    },
    {
      "id": "test",
      "description": "Test implementation"
    }
  ],
  "policies": [
    {
      "id": "on.trigger.plan_approved.then.developer.start.implementation",
      "source": "trigger",
      "trigger": "plan_approved",
      "agent": "developer",
      "action": "implementation",
      "enabled": true
    },
    {
      "id": "on.developer.implementation.complete.v1.then.developer.start.implementation",
      "source": "event",
      "event": "developer.implementation.complete.v1",
      "agent": "developer",
      "action": "implementation",
      "enabled": true
    },
    {
      "id": "on.developer.implementation.complete.v1.then.qa-verification-reviewer.start.review",
      "source": "event",
      "event": "developer.implementation.complete.v1",
      "agent": "qa-verification-reviewer",
      "action": "review",
      "enabled": true
    }
  ],
  "workflows": [
    {
      "id": "plan-implement-review",
      "title": "Plan, implement, review",
      "steps": [
        "on.trigger.plan_approved.then.developer.start.implementation",
        "on.developer.implementation.complete.v1.then.developer.start.implementation"
      ]
    }
  ],
  "runtimes": [
    {
      "id": "runtime-codex",
      "title": "codex-cli",
      "command": "codex",
      "args": []
    }
  ]
}
