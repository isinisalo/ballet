{
  "version": 1,
  "triggers": [
    {
      "id": "plan_approved",
      "description": "Plan approved"
    }
  ],
  "actions": [
    {
      "id": "implement",
      "description": "Implement an approved plan."
    },
    {
      "id": "review",
      "description": "Review implementation output."
    },
    {
      "id": "test",
      "description": "Test implementation"
    },
    {
      "id": "plan",
      "description": "Plan incomplete specs."
    }
  ],
  "policies": [
    {
      "id": "on.trigger.plan_approved.then.developer.start.implement",
      "source": "trigger",
      "trigger": "plan_approved",
      "agent": "developer",
      "action": "implement",
      "enabled": true
    },
    {
      "id": "on.developer.implement.complete.then.qa.start.test",
      "source": "event",
      "event": "developer.implement.complete",
      "agent": "qa",
      "action": "test",
      "enabled": true
    },
    {
      "id": "on.developer.implement.complete.then.qa-verification-reviewer.start.review",
      "source": "event",
      "event": "developer.implement.complete",
      "agent": "qa-verification-reviewer",
      "action": "review",
      "enabled": true
    },
    {
      "id": "on.qa.test.complete.then.ux.start.test",
      "source": "event",
      "event": "qa.test.complete",
      "agent": "ux",
      "action": "test",
      "enabled": true
    },
    {
      "id": "on.qa.test.cancelled.then.qa.start.test",
      "source": "event",
      "event": "qa.test.cancelled",
      "agent": "qa",
      "action": "test",
      "enabled": true
    }
  ],
  "workflows": [
    {
      "id": "plan-implement-review",
      "title": "Plan, implement, review",
      "steps": [
        "on.trigger.plan_approved.then.developer.start.implement",
        "on.developer.implement.complete.then.qa.start.test"
      ]
    }
  ],
  "runtimes": [
    {
      "id": "runtime-codex",
      "title": "codex-cli",
      "command": "codex",
      "args": []
    }
  ]
}
