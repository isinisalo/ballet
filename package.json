{
  "name": "ballet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsx watch backend/index.ts\"",
    "server": "tsx backend/index.ts",
    "daemon": "tsx backend/daemon/main.ts",
    "ballet": "tsx backend/cli/main.ts",
    "release:build": "sh scripts/build-release.sh",
    "release:install": "sh scripts/install-local.sh",
    "build": "rm -rf dist dist-server && tsc -b --force && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "npm run build && node dist-server/backend/index.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dagrejs/dagre": "3.0.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@github/copilot-sdk": "1.0.6",
    "@js-temporal/polyfill": "^0.5.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tisoap/react-flow-smart-edge": "^4.13.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.11.1",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "smol-toml": "^1.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "vite": "^6.0.1",
    "ws": "8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "8.18.1",
    "eslint": "^9.16.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vitest": "^4.1.10"
  }
